PORT=5000
NODE_ENV=development

# Local MongoDB or MongoDB Atlas (free M0 cluster)
MONGODB_URI=mongodb://127.0.0.1:27017/karma

# Use a long random string in production (Render dashboard → Environment)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRE=7d

# Public site URL (Render free: https://your-app.onrender.com)
CLIENT_URL=http://localhost:5173

# Google OAuth Web client ID (same value as VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=your_google_client_id

# Admin account (used by npm run prepare-host and seed)
ADMIN_EMAIL=admin@karmastore.np
ADMIN_PASSWORD=use_a_strong_password_here

# Email (Gmail app password or SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Karma Support <noreply@yourdomain.com>"
