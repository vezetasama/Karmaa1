# Vite public env vars
# Google Sign-In: use the same Web client ID as server GOOGLE_CLIENT_ID. In Google Cloud Console → Credentials → your
# OAuth 2.0 Web client → Authorized JavaScript origins, add every dev URL you open in the browser, e.g.:
#   http://localhost:5173
#   http://127.0.0.1:5173
# (localhost and 127.0.0.1 are different origins — add both if you use both.)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
VITE_API_BASE_URL=https://protective-sparkle-production-f0c9.up.railway.app/api
VITE_SOCKET_URL=https://protective-sparkle-production-f0c9.up.railway.app
